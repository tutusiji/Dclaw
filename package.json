{
  "name": "dclaw",
  "version": "0.1.0",
  "private": true,
  "description": "Dclaw wraps OpenClaw in an Electron client with local automation and git reporting.",
  "main": "dist-electron/main/index.cjs",
  "type": "module",
  "scripts": {
    "dev": "electron-vite dev",
    "build": "electron-vite build",
    "preview": "electron-vite preview",
    "stage:openclaw-runtime": "node scripts/stage-openclaw-runtime.mjs",
    "typecheck": "tsc --noEmit -p tsconfig.json && tsc --noEmit -p tsconfig.node.json",
    "package": "pnpm stage:openclaw-runtime && npm run build && electron-builder"
  },
  "dependencies": {
    "react": "^18.3.1",
    "react-dom": "^18.3.1"
  },
  "optionalDependencies": {
    "docx": "^9.5.0",
    "pptxgenjs": "^3.12.0",
    "xlsx": "^0.18.5"
  },
  "devDependencies": {
    "@iconify-json/lucide": "^1.2.98",
    "@types/node": "^22.13.4",
    "@types/react": "^18.3.18",
    "@types/react-dom": "^18.3.5",
    "@unocss/preset-icons": "^66.6.7",
    "@unocss/preset-uno": "^66.6.7",
    "@vitejs/plugin-react": "^4.3.4",
    "electron": "^35.0.0",
    "electron-builder": "^25.1.8",
    "electron-vite": "^3.1.0",
    "typescript": "^5.8.2",
    "unocss": "^66.6.7",
    "vite": "^6.2.0"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "electron",
      "esbuild"
    ]
  },
  "build": {
    "appId": "com.openclaw.dclaw",
    "productName": "Dclaw",
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/**/*",
      "dist-electron/**/*",
      "package.json"
    ],
    "extraResources": [
      {
        "from": "vendor/openclaw-runtime",
        "to": "openclaw-runtime",
        "filter": [
          "**/*"
        ]
      }
    ]
  }
}
